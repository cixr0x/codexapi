HOST=127.0.0.1
PORT=3001
CODEX_WORKSPACE=C:\PROJECTS\codexapi
# Windows default uses the npm Codex Node script automatically when APPDATA is set.
# Override these if Codex is installed somewhere else.
CODEX_COMMAND=
CODEX_COMMAND_ARGS=
CODEX_PROFILE=plain
CODEX_IGNORE_USER_CONFIG=true
CODEX_DISABLE_PLUGINS=true
CODEX_DISABLE_SHELL_SNAPSHOT=true
CODEX_EPHEMERAL=true
CODEX_IGNORE_RULES=true
CODEX_TIMEOUT_MS=120000
# Fallback model used when request body model is absent or blank.
CODEX_DEFAULT_MODEL=gpt-5.4-mini
# Comma- or semicolon-separated model ids accepted from request bodies.
CODEX_ALLOWED_MODELS=gpt-5.4-mini,gpt-5.5,gpt-5.3-codex-spark,gpt-5.4
# Reasoning effort passed to Codex calls: minimal, low, medium, high, or xhigh.
CODEX_REASONING_EFFORT=medium
# Default: spawn `codex exec` per request. Experimental: use a warm app-server.
CODEX_BACKEND=exec
# Optional. When unset and CODEX_BACKEND=app-server, this API starts a managed app-server.
CODEX_APP_SERVER_URL=
# 0 picks a free local port for a managed app-server.
CODEX_APP_SERVER_PORT=0
CODEX_APP_SERVER_START_TIMEOUT_MS=10000
CODEX_APP_SERVER_DISABLE_APPS=true
CODEX_APP_SERVER_DISABLE_NODE_REPL_MCP=true
OPENAI_COMPAT_MODEL=local-codex
CODEX_CALL_LOGGING=false
CODEX_CALL_LOG_DIR=.codexapi\logs
