HOST=127.0.0.1
PORT=3000
CODEX_WORKSPACE=C:\PROJECTS\codexapi
# Windows default uses the npm Codex Node script automatically when APPDATA is set.
# Override these if Codex is installed somewhere else.
CODEX_COMMAND=
CODEX_COMMAND_ARGS=
CODEX_PROFILE=plain
CODEX_IGNORE_USER_CONFIG=true
CODEX_DISABLE_PLUGINS=true
CODEX_DISABLE_SHELL_SNAPSHOT=true
CODEX_EPHEMERAL=true
CODEX_IGNORE_RULES=true
CODEX_TIMEOUT_MS=120000
OPENAI_COMPAT_MODEL=local-codex
CODEX_CALL_LOGGING=false
CODEX_CALL_LOG_DIR=.codexapi\logs
