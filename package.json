{
  "name": "codexapi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:codex": "node -e \"const {spawn}=require('node:child_process'); const child=spawn('tsx',['watch','src/server.ts'],{stdio:'inherit',shell:true,env:{...process.env,HOST:'127.0.0.1',PORT:'3001'}}); child.on('exit',code=>process.exit(code ?? 0));\"",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
